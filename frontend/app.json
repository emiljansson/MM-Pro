{
  "expo": {
    "name": "Matematikmästaren Pro",
    "slug": "mathmaster-pro",
    "version": "2.0.194",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mathmaster",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "updates": {
      "enabled": false
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1B2A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emja.mathmasterpro",
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:api.mathematicsmaster.app",
        "applinks:www.api.mathematicsmaster.app"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Ta bilder för din profil",
        "NSPhotoLibraryUsageDescription": "Välj profilbild från galleri"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0D1B2A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emja.mathmasterpro",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "api.mathematicsmaster.app",
              "pathPrefix": "/challenge"
            },
            {
              "scheme": "https",
              "host": "www.api.mathematicsmaster.app",
              "pathPrefix": "/challenge"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0D1B2A"
        }
      ],
      "expo-localization",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e3803b80-8939-4e2c-8635-e52e3e0d0fd6"
      }
    },
    "owner": "emja"
  }
}
